# GPTImage runtime configuration. Copy to config/gptimage.toml and edit.
# Secrets are never stored here: they are read from the environment variables
# named below (password_env, api_key_env).

[database]
# Postgres holding ONLY the auth store (static tokens + the OAuth server's
# clients/codes/refresh tokens/credentials). No image is ever stored here.
# For stdio-only local use you still need a reachable DB for `migrate`, but the
# generate/edit tools never touch it.
host         = "127.0.0.1"
port         = 5432
dbname       = "gptimage"
user         = "gptimage_rw"              # dedicated role, see sql/setup/create_role.sql
password_env = "GPTIMAGE_DB_PASSWORD"
schema       = "gptimage"
sslmode      = ""                         # "" = libpq default (prefer). Set "require" on an untrusted network.

[image]
# The whole point of the server. gpt-image-2 is "ChatGPT Images 2.0".
model               = "gpt-image-2"
api_key_env         = "OPENAI_API_KEY"    # the key lives in the environment, not here
generations_endpoint = "https://api.openai.com/v1/images/generations"
edits_endpoint       = "https://api.openai.com/v1/images/edits"
# Public origin this server is reachable at (no trailing slash). When set, a
# finished render is also served at <public_base_url>/i/<job_id>-<index>.<ext>
# and the tools hand the client a markdown image link, so the picture renders in
# the conversation body instead of only inside the collapsed tool-call block.
# Leave it commented to inherit auth.oauth.issuer when OAuth is on; empty with no
# issuer (stdio/local) means inline base64 only, nothing is hosted.
# public_base_url   = "https://gptimage.specterpoint.com"
# Defaults applied when a tool call omits the field.
default_size        = "1024x1024"         # WxH (÷16, aspect 1:3..3:1, up to 2K) or "auto"
# low keeps interactive generations fast (~15-30s). high looks best but a large
# high render can take ~2 min and exceed a remote connector's tool-call timeout.
default_quality     = "low"               # auto | low | medium | high
default_background  = "auto"              # transparent | opaque | auto (transparent not always honored)
# webp, not png: an inline image round-trips as base64 and a full-res png
# (1.5-3 MB) is large enough that claude.ai drops the tool result and nothing
# renders. webp + compression keeps the payload light. Override to png per call
# when you need lossless output.
default_format      = "webp"              # png | jpeg | webp
default_compression = 80                  # webp/jpeg quality 0-100 (higher = better/larger); ignored for png
moderation          = "low"               # auto | low (low is permissive but still filtered)
max_n               = 4                   # hard cap on images per call (cost guard)
timeout_s           = 180                 # high quality / 2K can be slow
max_retries         = 4
backoff_initial_ms  = 800
# Async job pattern: gptimage_generate/gptimage_edit start a background render
# and return fast; gptimage_result (read-only, so it never trips a write-approval
# prompt) fetches it. Each generate/result call blocks up to job_poll_seconds,
# kept under any remote connector's tool-call timeout, so a fast render lands in
# one call and a slow one is polled in safe chunks.
job_poll_seconds    = 25
# How long a finished render stays in the in-memory cache after it completes.
# This is the window its hosted URL stays live, so it must outlast the client
# fetching and rendering the link; then the render is dropped and nothing is
# persisted. Pending jobs are never evicted.
job_ttl_seconds     = 900
max_concurrent_jobs = 4

[mcp]
transport = "stdio"                       # "stdio" for desktop clients | "http" for the remote endpoint
tcp_bind  = "127.0.0.1:17718"             # legacy stub
# HTTP (Streamable HTTP). Binds loopback; Caddy terminates TLS in front and
# proxies https://gptimage.specterpoint.com/mcp -> here.
http_bind            = "127.0.0.1:17718"
http_max_body_bytes  = 33554432           # 32 MiB: an inline image is large
http_read_timeout_s  = 30
http_write_timeout_s = 200

[auth]
# Only enforced for transport = "http". stdio trusts the OS boundary.
enabled = true
# Derived from [auth.oauth] issuer/resource when oauth is enabled; set
# explicitly only to override.
# resource_metadata_url = "https://gptimage.specterpoint.com/.well-known/oauth-protected-resource/mcp"

# [auth.oauth] — the embedded OAuth 2.1 authorization server. This is what lets
# claude.ai and ChatGPT add GPTImage as a remote connector: RFC 8414/9728
# discovery, RFC 7591 dynamic client registration, PKCE authorization-code flow,
# and a built-in login page backed by `gptimage_cli passwd`. VPS only; leave
# disabled for local stdio use.
# [auth.oauth]
# enabled             = true
# issuer              = "https://gptimage.specterpoint.com"      # no trailing slash
# resource            = "https://gptimage.specterpoint.com/mcp"  # canonical resource (RFC 8707) = token audience
# signing_key_path    = "/etc/gptimage/oauth_signing_key.pem"    # mint: gptimage_cli oauth keygen
# previous_key_paths  = []            # rotated-out keys, kept in JWKS until their tokens age out
# access_token_ttl_s  = 900           # 15 min; no revocation store, so keep short (refresh carries longevity)
# auth_code_ttl_s     = 600
# refresh_token_ttl_s = 2592000
# redirect_hosts      = ["claude.ai", "claude.com", "chatgpt.com", "openai.com"]
# max_clients         = 50
#
# Optional extra secret (env var, never a config key):
#   GPTIMAGE_PASSWORD_PEPPER — if set, login passwords are HMAC'd with it before
#   scrypt, so a stolen credentials table alone is uncrackable. Set it, then
#   re-run `gptimage_cli passwd` for each principal to re-hash.

# Principal template: the grant a freshly-minted token inherits
# (gptimage_cli tokens add --principal <name>) and the grant a JWT subject maps
# to once OAuth is enabled. Realm scoping is unused by the image tools, so a
# single all-realms operator is all you need.
[[auth.principals]]
name         = "operator"
home_realm   = "default"
read_realms  = ["*"]
write_realms = ["*"]

[logging]
level        = "info"
path         = "/var/log/gptimage"        # rotating mcp.log written here for http transport
rotate_mb    = 25
retain_files = 10
