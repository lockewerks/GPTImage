root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{h,hpp,c,cpp,cc,cxx,inl}]
indent_size = 4

[CMakeLists.txt]
indent_size = 4

[*.{cmake,cmake.in}]
indent_size = 4

[*.{yml,yaml,toml,json}]
indent_size = 2

[*.{ps1,psm1,psd1}]
end_of_line = crlf
indent_size = 4

[*.md]
trim_trailing_whitespace = false
indent_size = 2

[*.sql]
indent_size = 4

[Makefile]
indent_style = tab
